{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "profiles": {
      ".read": "auth != null",
      "$profileId": {
        ".write": "auth != null && newData.child('ownerUserId').val() === auth.uid"
      }
    },
    "profiles_by_owner": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
